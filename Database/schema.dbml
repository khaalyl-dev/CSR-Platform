Project Csr_Insight {
  database_type: "MySQL"
  note: "Base MySQL 8+. Schéma aligné avec backend/models/"
}

//////////////////////////////////////////////////////
//////////////////// ENUMS ///////////////////////////
//////////////////////////////////////////////////////

Enum user_role {
  SITE_USER
  CORPORATE_USER
}

Enum plan_status {
  DRAFT
  SUBMITTED
  VALIDATED
  REJECTED
  LOCKED
}

Enum activity_status {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
  VALIDATED
}

Enum validation_status {
  PENDING
  APPROVED
  REJECTED
}

Enum entity_type {
  PLAN
  ACTIVITY
}

Enum partner_type {
  NGO
  SCHOOL
  ASSOCIATION
  SUPPLIER
  GOVERNMENT
  OTHER
}

// From Annual CSR Plan: Organization (Internal / Partnership)
Enum organization_type {
  INTERNAL
  PARTNERSHIP
}

// From Annual CSR Plan: Contract type (One shot / Successive performance)
Enum contract_type {
  ONE_SHOT
  SUCCESSIVE_PERFORMANCE
}

// From Consolidated Report: Nature of collaboration
Enum collaboration_nature {
  CHARITY_DONATION
  PARTNERSHIP
  SPONSORSHIP
  OTHERS
}

//////////////////////////////////////////////////////
//////////////////// USERS & SITES ///////////////////
//////////////////////////////////////////////////////

Table users {
  id uuid [pk]
  first_name varchar
  last_name varchar
  email varchar [unique]
  password_hash varchar
  role user_role
  is_active boolean
  is_corporate_global boolean [default: false, note: 'Accès corporate global']
  avatar_url varchar [null, note: 'Photo de profil']
  phone varchar [null]
  language varchar [default: 'en']
  theme varchar [default: 'light']
  notify_csr_plan_validation boolean [default: true]
  notify_activity_validation boolean [default: true]
  notify_activity_reminders boolean [default: true]
  notify_weekly_summary_email boolean [default: true]
  created_at timestamp
  updated_at timestamp
}

Table user_sessions {
  id uuid [pk]
  user_id uuid
  refresh_token varchar
  ip_address varchar
  user_agent varchar
  expires_at timestamp
  created_at timestamp
}

Ref: user_sessions.user_id > users.id

// Site = Plant/COFICAB Entity; region & country from Consolidated Report
Table sites {
  id uuid [pk]
  name varchar
  code varchar [unique]
  region varchar [null]
  country varchar [null]
  location varchar [null]
  description text [null]
  is_active boolean [default: true]
  created_at timestamp
  updated_at timestamp
}

Table user_sites {
  id uuid [pk]
  user_id uuid
  site_id uuid
  grade varchar [null, note: 'level_0, level_1, level_2']
  is_active boolean [default: true]
  granted_by uuid [null]
  granted_at timestamp [null]
}

Ref: user_sites.user_id > users.id
Ref: user_sites.site_id > sites.id
Ref: user_sites.granted_by > users.id

//////////////////////////////////////////////////////
//////////////////// CATEGORIES //////////////////////
//////////////////////////////////////////////////////

Table categories {
  id uuid [pk]
  name varchar
  description text [null]
  created_at timestamp
  updated_at timestamp
}

//////////////////////////////////////////////////////
//////////////// EXTERNAL PARTNERS ///////////////////
//////////////////////////////////////////////////////

Table external_partners {
  id uuid [pk]
  name varchar
  type partner_type
  contact_person varchar [null]
  email varchar [null]
  phone varchar [null]
  address text [null]
  website varchar [null]
  description text [null]
  is_active boolean [default: true]
  created_at timestamp
  updated_at timestamp
}

//////////////////////////////////////////////////////
//////////////////// CSR PLAN ////////////////////////
//////////////////////////////////////////////////////

Table csr_plans {
  id uuid [pk]
  site_id uuid
  year int
  validation_mode varchar [default: '101', note: '101 ou 111']
  status plan_status
  total_budget decimal [null]
  submitted_at timestamp [null]
  rejected_comment text [null]
  rejected_activity_ids text [null, note: 'JSON array of activity UUIDs']
  validation_step int [null]
  validated_at timestamp [null]
  unlock_until timestamp [null, note: 'Date limite modification après demande approuvée']
  unlock_since timestamp [null]
  created_by uuid [null]
  created_at timestamp
  updated_at timestamp

  indexes {
    (site_id, year) [unique]
  }
}

Ref: csr_plans.site_id > sites.id
Ref: csr_plans.created_by > users.id

//////////////////////////////////////////////////////
//////////////// CSR ACTIVITIES //////////////////////
//////////////////////////////////////////////////////
// Aligned with: Annual CSR Plan + Consolidated Report (Group figures)

Table csr_activities {
  id uuid [pk]
  plan_id uuid
  category_id uuid
  external_partner_id uuid [null]
  activity_number varchar
  title varchar
  description text [null]
  activity_type varchar [null]
  organization organization_type
  collaboration_nature collaboration_nature [null]
  contract_type contract_type
  periodicity varchar [null]
  is_off_plan boolean [default: false]
  planned_budget decimal [null]
  planned_volunteers int [null]
  action_impact_target decimal [null]
  action_impact_unit varchar [null]
  action_impact_duration varchar [null]
  sustainability_description text [null]
  start_year int [null]
  edition int [null]
  organizer varchar [null]
  responsible_user_id uuid [null]
  start_date date [null]
  end_date date [null]
  status activity_status
  kpi_value decimal [null]
  kpi_unit varchar [null]
  created_at timestamp
  updated_at timestamp

  indexes {
    (plan_id)
    (category_id)
    (plan_id, activity_number) [unique]
  }
}

Ref: csr_activities.plan_id > csr_plans.id
Ref: csr_activities.category_id > categories.id
Ref: csr_activities.responsible_user_id > users.id
Ref: csr_activities.external_partner_id > external_partners.id

Table activity_kpis {
  id uuid [pk]
  activity_id uuid
  name varchar
  target_value decimal
  actual_value decimal [null]
  unit varchar
}

Ref: activity_kpis.activity_id > csr_activities.id

//////////////////////////////////////////////////////
//////////////// REALIZED CSR ////////////////////////
//////////////////////////////////////////////////////
// Aligned with: CSR Reporting form + Consolidated Report (Actual Budget, Participants, Impact, etc.)

Table realized_csr {
  id uuid [pk]
  activity_id uuid
  year int
  month int
  realized_budget decimal [null]
  participants int [null]
  total_hc int [null]
  percentage_employees decimal [null]
  volunteer_hours decimal [null]
  action_impact_actual decimal [null]
  action_impact_unit varchar [null]
  impact_description text [null]
  organizer varchar [null]
  number_external_partners int [null]
  realization_date date [null]
  comment text [null]
  contact_department varchar [null]
  contact_name varchar [null]
  contact_email varchar [null]
  created_by uuid [null]
  created_at timestamp
}

Ref: realized_csr.activity_id > csr_activities.id
Ref: realized_csr.created_by > users.id

//////////////////////////////////////////////////////
//////////////// VALIDATION WORKFLOW /////////////////
//////////////////////////////////////////////////////

Table validations {
  id uuid [pk]
  entity_type entity_type
  entity_id uuid
  site_id uuid
  grade varchar [null, note: 'level_1, level_2']
  status validation_status
  validated_by uuid [null]
  comment text [null]
  rejected_activity_ids text [null, note: 'JSON array of activity UUIDs']
  validated_at timestamp [null]
  created_at timestamp

  indexes {
    (entity_type, entity_id, grade) [unique]
  }
}

Ref: validations.site_id > sites.id
Ref: validations.validated_by > users.id

Table validation_steps {
  id uuid [pk]
  validation_id uuid
  level int
  validator_id uuid
  status validation_status
  comment text
  validated_at timestamp [null]
}

Ref: validation_steps.validation_id > validations.id
Ref: validation_steps.validator_id > users.id

//////////////////////////////////////////////////////
//////////////// CHANGE REQUESTS /////////////////////
//////////////////////////////////////////////////////

Table change_requests {
  id uuid [pk]
  site_id uuid
  entity_type entity_type
  entity_id uuid
  year int
  reason text [null]
  status validation_status
  requested_by uuid
  requested_duration varchar [null, note: 'ex: 30 days']
  validation_mode varchar [null, note: '101 ou 111']
  reviewed_by uuid [null]
  reviewed_at timestamp [null]
  created_at timestamp
}

Ref: change_requests.site_id > sites.id
Ref: change_requests.requested_by > users.id
Ref: change_requests.reviewed_by > users.id

//////////////////////////////////////////////////////
//////////////// DOCUMENT MANAGEMENT /////////////////
//////////////////////////////////////////////////////

Table documents {
  id uuid [pk]
  site_id uuid [null]
  entity_type varchar [null]
  entity_id uuid [null]
  file_name varchar
  file_path varchar
  file_type varchar [null]
  is_pinned boolean [default: false]
  change_request_id uuid [null]
  uploaded_by uuid [null]
  uploaded_at timestamp
  updated_at timestamp
}

Ref: documents.site_id > sites.id
Ref: documents.change_request_id > change_requests.id
Ref: documents.uploaded_by > users.id

//////////////////////////////////////////////////////
//////////////// AUDIT & HISTORY /////////////////////
//////////////////////////////////////////////////////

Table audit_logs {
  id uuid [pk]
  site_id uuid [null]
  user_id uuid [null]
  action varchar
  entity_type entity_type
  entity_id uuid [null]
  description text [null]
  entity_history_id uuid [null]
  created_at timestamp
}

Ref: audit_logs.site_id > sites.id
Ref: audit_logs.user_id > users.id
Ref: audit_logs.entity_history_id > entity_history.id

Table entity_history {
  id uuid [pk]
  site_id uuid [null]
  entity_type entity_type
  entity_id uuid [null]
  old_data json [null, note: 'JSON - NULL for CREATE']
  new_data json [null, note: 'JSON - NULL for DELETE']
  modified_by uuid [null]
  modified_at timestamp
}

Ref: entity_history.site_id > sites.id
Ref: entity_history.modified_by > users.id

//////////////////////////////////////////////////////
//////////////// NOTIFICATIONS ///////////////////////
//////////////////////////////////////////////////////

Table notifications {
  id uuid [pk]
  user_id uuid
  site_id uuid [null]
  title varchar
  message text [null]
  type varchar [default: 'info']
  entity_type varchar [null, note: 'PLAN, CHANGE_REQUEST, etc.']
  entity_id uuid [null]
  is_read boolean [default: false]
  created_at timestamp
}

Ref: notifications.user_id > users.id
Ref: notifications.site_id > sites.id

Table user_notifications {
  id uuid [pk]
  user_id uuid
  notification_id uuid
  is_read boolean
  read_at timestamp [null]
  created_at timestamp
}

Ref: user_notifications.notification_id > notifications.id
Ref: user_notifications.user_id > users.id

Table notification_settings {
  id uuid [pk]
  user_id uuid
  site_id uuid
  email_enabled boolean
}

Ref: notification_settings.user_id > users.id
Ref: notification_settings.site_id > sites.id

//////////////////////////////////////////////////////
//////////////// POWER BI SNAPSHOTS //////////////////
//////////////////////////////////////////////////////

Table csr_snapshots {
  id uuid [pk]
  site_id uuid
  year int
  month int
  total_budget decimal [null]
  total_realized decimal [null]
  total_activities int [null]
  completion_rate decimal [null]
  created_at timestamp

  indexes {
    (site_id, year, month) [unique]
  }
}

Ref: csr_snapshots.site_id > sites.id

//////////////////////////////////////////////////////
//////////////// CHATBOT LOG /////////////////////////
//////////////////////////////////////////////////////

Table chatbot_logs {
  id uuid [pk]
  user_id uuid
  site_id uuid [null]
  question text [null]
  answer text [null]
  created_at timestamp
}

Ref: chatbot_logs.user_id > users.id
Ref: chatbot_logs.site_id > sites.id
